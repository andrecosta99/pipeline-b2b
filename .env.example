# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Motor de pesquisa para descoberta de dominio (Fase 2)
# search_provider = google | bing
SEARCH_PROVIDER=google
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
BING_SEARCH_API_KEY=

# Base de dados
DATABASE_PATH=data/pipeline.db

# Rate limiting (segundos entre pedidos, escolhido aleatoriamente no intervalo)
RATE_LIMIT_MIN_SECONDS=3
RATE_LIMIT_MAX_SECONDS=5

# Fase 1 - Portal da Justica
MJ_DISTRITO=Aveiro
MJ_DISTRITO_CODIGO=01
# Janela de datas da pesquisa (formato AAAA-MM-DD). Vazio = ultimos 30 dias.
MJ_DATA_INICIO=
MJ_DATA_FIM=

# Playwright
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_USER_DATA_DIR=data/playwright_profile

# Limite de seguranca de paginas a percorrer nos resultados (vazio = sem limite)
MJ_MAX_PAGINAS=

# User-Agent usado nos pedidos requests
HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36
